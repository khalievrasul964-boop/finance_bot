# services/reminder_service.py
"""Управление напоминаниями о записи операций."""
import aiosqlite
import logging
from config.settings import DB_PATH

logger = logging.getLogger(__name__)


async def set_reminder(user_id: int, telegram_id: int, reminder_time: str) -> bool:
    """reminder_time формат: 'HH:MM', например '21:00'"""
    try:
        async with aiosqlite.connect(DB_PATH) as db:
            # Удаляем старое напоминание если есть
            await db.execute("DELETE FROM reminders WHERE user_id = ?", (user_id,))
            await db.execute(
                "INSERT INTO reminders (user_id, telegram_id, reminder_time) VALUES (?, ?, ?)",
                (user_id, telegram_id, reminder_time)
            )
            await db.commit()
        return True
    except Exception as e:
        logger.error(f"❌ set_reminder: {e}", exc_info=True)
        return False


async def delete_reminder(user_id: int) -> bool:
    try:
        async with aiosqlite.connect(DB_PATH) as db:
            await db.execute("DELETE FROM reminders WHERE user_id = ?", (user_id,))
            await db.commit()
        return True
    except Exception:
        return False


async def get_reminder(user_id: int) -> dict | None:
    try:
        async with aiosqlite.connect(DB_PATH) as db:
            cursor = await db.execute(
                "SELECT reminder_time, is_active FROM reminders WHERE user_id = ?",
                (user_id,)
            )
            row = await cursor.fetchone()
        if not row:
            return None
        return {"time": row[0], "is_active": bool(row[1])}
    except Exception:
        return None


async def get_all_active_reminders() -> list:
    """Возвращает всех пользователей с активными напоминаниями."""
    try:
        async with aiosqlite.connect(DB_PATH) as db:
            cursor = await db.execute(
                """SELECT r.user_id, r.telegram_id, r.reminder_time, u.timezone
                   FROM reminders r
                   JOIN users u ON r.user_id = u.id
                   WHERE r.is_active = 1"""
            )
            rows = await cursor.fetchall()
        return [
            {"user_id": r[0], "telegram_id": r[1],
             "reminder_time": r[2], "timezone": r[3]}
            for r in rows
        ]
    except Exception:
        return []