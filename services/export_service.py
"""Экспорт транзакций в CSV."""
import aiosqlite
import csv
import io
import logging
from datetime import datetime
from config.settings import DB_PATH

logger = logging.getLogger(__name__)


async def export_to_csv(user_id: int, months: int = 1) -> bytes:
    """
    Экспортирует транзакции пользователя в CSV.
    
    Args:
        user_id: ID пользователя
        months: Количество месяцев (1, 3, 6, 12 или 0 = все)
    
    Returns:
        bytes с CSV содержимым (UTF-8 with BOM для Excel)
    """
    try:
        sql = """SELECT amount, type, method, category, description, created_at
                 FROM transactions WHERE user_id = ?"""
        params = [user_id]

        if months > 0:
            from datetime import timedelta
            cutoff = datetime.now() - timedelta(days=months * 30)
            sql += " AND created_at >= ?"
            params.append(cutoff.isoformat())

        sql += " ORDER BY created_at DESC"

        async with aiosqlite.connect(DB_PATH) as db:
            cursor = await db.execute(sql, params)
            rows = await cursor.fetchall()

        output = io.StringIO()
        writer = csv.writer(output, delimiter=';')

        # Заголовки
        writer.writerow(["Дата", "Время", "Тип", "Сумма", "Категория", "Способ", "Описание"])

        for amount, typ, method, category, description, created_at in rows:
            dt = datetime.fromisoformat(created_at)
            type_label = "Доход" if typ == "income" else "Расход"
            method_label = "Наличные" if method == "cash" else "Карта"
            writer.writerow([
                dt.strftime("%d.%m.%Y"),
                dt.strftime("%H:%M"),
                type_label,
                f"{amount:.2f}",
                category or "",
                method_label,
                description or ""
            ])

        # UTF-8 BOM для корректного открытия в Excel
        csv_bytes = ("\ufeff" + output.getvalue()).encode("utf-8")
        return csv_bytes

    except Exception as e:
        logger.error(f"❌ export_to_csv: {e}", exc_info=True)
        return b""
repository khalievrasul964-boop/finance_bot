# services/export_service.py
"""Экспорт транзакций в CSV."""
import aiosqlite
import csv
import io
import logging
from datetime import datetime
from config.settings import DB_PATH

logger = logging.getLogger(__name__)


async def export_to_csv(user_id: int, months: int = 1) -> bytes:
    """
    Экспортирует транзакции пользователя в CSV.
    
    Args:
        user_id: ID пользователя
        months: Количество месяцев (1, 3, 6, 12 или 0 = все)
    
    Returns:
        bytes с CSV содержимым (UTF-8 with BOM для Excel)
    """
    try:
        sql = """SELECT amount, type, method, category, description, created_at
                 FROM transactions WHERE user_id = ?"""
        params = [user_id]

        if months > 0:
            from datetime import timedelta
            cutoff = datetime.now() - timedelta(days=months * 30)
            sql += " AND created_at >= ?"
            params.append(cutoff.isoformat())

        sql += " ORDER BY created_at DESC"

        async with aiosqlite.connect(DB_PATH) as db:
            cursor = await db.execute(sql, params)
            rows = await cursor.fetchall()

        output = io.StringIO()
        writer = csv.writer(output, delimiter=';')

        # Заголовки
        writer.writerow(["Дата", "Время", "Тип", "Сумма", "Категория", "Способ", "Описание"])

        for amount, typ, method, category, description, created_at in rows:
            dt = datetime.fromisoformat(created_at)
            type_label = "Доход" if typ == "income" else "Расход"
            method_label = "Наличные" if method == "cash" else "Карта"
            writer.writerow([
                dt.strftime("%d.%m.%Y"),
                dt.strftime("%H:%M"),
                type_label,
                f"{amount:.2f}",
                category or "",
                method_label,
                description or ""
            ])

        # UTF-8 BOM для корректного открытия в Excel
        csv_bytes = ("\ufeff" + output.getvalue()).encode("utf-8")
        return csv_bytes

    except Exception as e:
        logger.error(f"❌ export_to_csv: {e}", exc_info=True)
        return b""