# services/recurring_service.py
"""Регулярные транзакции — автоматически применяются каждый месяц."""
import aiosqlite
import logging
from datetime import date, datetime
from config.settings import DB_PATH
from services.transaction_service import add_transaction

logger = logging.getLogger(__name__)


async def create_recurring(user_id: int, name: str, amount: float,
                            trans_type: str, method: str,
                            category: str, day_of_month: int) -> bool:
    try:
        async with aiosqlite.connect(DB_PATH) as db:
            await db.execute(
                """INSERT INTO recurring_transactions
                   (user_id, name, amount, type, method, category, day_of_month)
                   VALUES (?, ?, ?, ?, ?, ?, ?)""",
                (user_id, name, amount, trans_type, method, category, day_of_month)
            )
            await db.commit()
        return True
    except Exception as e:
        logger.error(f"❌ create_recurring: {e}", exc_info=True)
        return False


async def get_recurring_list(user_id: int) -> list:
    try:
        async with aiosqlite.connect(DB_PATH) as db:
            cursor = await db.execute(
                """SELECT id, name, amount, type, method, category, day_of_month, is_active, last_applied
                   FROM recurring_transactions WHERE user_id = ? ORDER BY day_of_month""",
                (user_id,)
            )
            rows = await cursor.fetchall()
        return [
            {"id": r[0], "name": r[1], "amount": r[2], "type": r[3],
             "method": r[4], "category": r[5], "day_of_month": r[6],
             "is_active": bool(r[7]), "last_applied": r[8]}
            for r in rows
        ]
    except Exception:
        return []


async def delete_recurring(user_id: int, recurring_id: int) -> bool:
    try:        async with aiosqlite.connect(DB_PATH) as db:
            await db.execute(
                "DELETE FROM recurring_transactions WHERE id = ? AND user_id = ?",
                (recurring_id, user_id)
            )
            await db.commit()
        return True
    except Exception:
        return False


async def apply_due_recurring(user_id: int, user_name: str) -> list:
    """
    Применяет все регулярные транзакции, которые должны выполниться сегодня.
    Возвращает список применённых транзакций.
    """
    today = date.today()
    applied = []
    try:
        async with aiosqlite.connect(DB_PATH) as db:
            cursor = await db.execute(
                """SELECT id, name, amount, type, method, category, day_of_month, last_applied
                   FROM recurring_transactions
                   WHERE user_id = ? AND is_active = 1""",
                (user_id,)
            )
            rows = await cursor.fetchall()

        for r in rows:
            rid, name, amount, rtype, method, category, dom, last_applied = r

            # Проверяем: сегодня нужный день месяца?
            if today.day != dom:
                continue

            # Уже применяли в этом месяце?
            if last_applied:
                last = date.fromisoformat(last_applied)
                if last.year == today.year and last.month == today.month:
                    continue

            # Применяем
            success = await add_transaction(
                user_id, amount, rtype, method, user_name, category=category,
                description=f"Автоматически: {name}"
            )
            if success:
                async with aiosqlite.connect(DB_PATH) as db:
                    await db.execute(
                        "UPDATE recurring_transactions SET last_applied = ? WHERE id = ?",                        (today.isoformat(), rid)
                    )
                    await db.commit()
                applied.append({"name": name, "amount": amount, "type": rtype, "category": category})
                logger.info(f"✅ Применена регулярная транзакция '{name}' для {user_name}")

    except Exception as e:
        logger.error(f"❌ apply_due_recurring: {e}", exc_info=True)
    return applied